react-reveal\";\nimport \"./ContactComponent.css\";\nimport { greeting, contactPageData } from \"../../portfolio.js\";\nimport { style } from \"glamor\";\n\nconst ContactData = contactPageData.contactSection;\nconst blogSection = contactPageData.blogSection;\n\nfunction Contact(props) {\n  const theme = props.theme;\n\n  const styles = style({\n    backgroundColor: `${theme.accentBright}`,\n    \":hover\": {\n      boxShadow: `0 5px 15px ${theme.accentBright}`,\n    },\n  });\n\n  return (\n    <div className=\"contact-main\">\n      <Header theme={theme} setTheme={props.setTheme} />\n      <div className=\"basic-contact\">\n        <Fade bottom duration={1000} distance=\"40px\">\n          <div className=\"contact-heading-div\">\n            <div className=\"contact-heading-img-div\">\n              <img\n                className=\"profile-pic\"\n                src={require(`../../assests/images/${ContactData[\"profile_image_path\"]}`)}\n                alt=\"\"\n                style={{\n                  maxWidth: \"95%\",\n                  height: \"auto\",\n                  objectFit: \"cover\", // or 'contain', 'fill', 'none', etc. depending on your requirement\n                  objectPosition: \"center\" // or any other position you prefer\n                }}\n              />\n            </div>\n            <div className=\"contact-heading-text-div\">\n              <h1\n                className=\"contact-heading-text\"\n                style={{ color: theme.text }}\n              >\n                {ContactData[\"title\"]}\n              </h1>\n              <p\n                className=\"contact-header-detail-text subTitle\"\n                style={{ color: theme.secondaryText }}\n              >\n                {ContactData[\"description\"]}\n              </p>\n              <SocialMedia />\n              <br />\n              <br />\n              <a {...styles} className=\"general-btn\" href={greeting.resumeLink}>\n                My Resume\n              </a>\n            </div>\n          </div>\n        </Fade>\n        <Fade bottom duration={1000} distance=\"40px\">\n          <div className=\"blog-heading-div\">\n            <div className=\"blog-heading-text-div\">\n            </div>\n            <div className=\"blog-heading-img-div\">\n              <BlogsImg theme={theme} />\n            </div>\n          </div>\n        </Fade>\n      </div>\n      <Footer theme={props.theme} onToggle={props.onToggle} />\n    </div>\n  );\n}\n\nexport default Contact;\n","/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/containers/experienceAccordion/ExperienceAccordion.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/pages/experience/ExperienceImg.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/pages/contact/BlogsImg.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/containers/skills/Skills.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/containers/greeting/Greeting.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/components/header/Header.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/components/socialMedia/SocialMedia.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/components/footer/Footer.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/components/experienceCard/ExperienceCard.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/containers/skills/SkillSection.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/containers/greeting/FeelingProud.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/containers/skills/CloudInfraImg.js",[],[],"/Users/arpitkohli/Documents/ArpitGitPortfolio/arpitgitportfolio/src/containers/skills/FullStackImg.js",[],[],"/Users/arpitkohli/Documents